NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Configuration (when connecting to FastAPI)
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_key_here_for_production

# Database (future)
DATABASE_URL=postgresql://user:password@localhost:5432/tvacha_clinic

# Payment Gateway (future)
NEXT_PUBLIC_RAZORPAY_KEY=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# AWS S3 for Patient Photos (future)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=tvacha-clinic-photos
AWS_REGION=ap-south-1

# Analytics (future)
NEXT_PUBLIC_GA_ID=google_analytics_id

# Email Service (future)
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@tvachaclinic.com

# SMS Service (future) 
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
