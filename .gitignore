node_modules/
.next/
.env
.env.local
.env.*.local
.DS_Store
*.pem
.idea/
.vscode/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/

# Archived assets pulled out of /public during perf optimization — kept on disk
# so we can restore easily, but not deployed. See: perf(phase-1) commit.
_archived/

# Phase 5 perf tooling outputs — generated on demand, never committed.
# README and the *.example reference traces in perf-reports/ ARE committed;
# the dynamic outputs below are not.
.lighthouseci/
perf-reports/analyze/
perf-reports/profiler/*.json
perf-reports/lhci/
# measure.sh writes per-label snapshots (e.g. perf-reports/baseline/,
# perf-reports/after-phase-3/). Ignore everything except the README.
perf-reports/*/
!perf-reports/.gitkeep

# Per-phase build snapshots used while tuning size-limit budgets.
after-phase-*-build.txt
knip-report.txt

# Intermediate output from scripts/record-vine-video.mjs — frame PNGs are
# regenerated on demand; only the encoded videos under public/ ship.
scratch/

